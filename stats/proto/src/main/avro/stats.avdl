@namespace("ru.practicum.ewm.stats.avro")
protocol StatsProtocol {

    enum ActionTypeAvro {
        VIEW, REGISTER, LIKE
    }

    record UserActionAvro {
        long user_id;
        long event_id;
        ActionTypeAvro action_type;
        timestamp_ms timestamp;
    }

    record EventSimilarityAvro {
        long eventA;
        long eventB;
        double score;
        timestamp_ms timestamp;
    }

}
